
#
# Gemini 3.5 Flash Generated.
# For Deploying Server
#

FROM golang:1.22 AS builder

WORKDIR /app

# copy module files from correct folder
COPY src/Server/go.mod src/Server/go.sum ./
RUN go mod download

# copy full server source
COPY src/Server/ ./

ENV CGO_ENABLED=0
ENV GOOS=linux
ENV GOARCH=amd64

RUN go build -ldflags="-s -w" -o server .

FROM alpine:latest

WORKDIR /app
RUN apk --no-cache add ca-certificates

COPY --from=builder /app/server .

EXPOSE 8080

CMD ["./server"]